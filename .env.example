# What's My IP - Environment Configuration
# Copy this file to .env and fill in your values

# MaxMind GeoLite2 License Key (required for geolocation)
# Get your free license key at https://www.maxmind.com/en/geolite2/signup
MAXMIND_LICENSE_KEY=your_license_key_here

# MaxMind Account ID (required for newer accounts)
# MAXMIND_ACCOUNT_ID=your_account_id

# Development: override the detected IP address (useful when running locally)
# DEV_IP=8.8.8.8