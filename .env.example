# What's My IP - Environment Configuration
# Copy this file to .env and fill in your values

# Application
NODE_ENV=production
PORT=3000

# IP2Location LITE Download Token (required for geolocation)
# Get your free token at https://lite.ip2location.com
IP2LOCATION_TOKEN=your_token_here

# Development: override the detected IP address (useful when running locally)
# DEV_IP=8.8.8.8
